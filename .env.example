# OpenRouter API Configuration (or any OpenAI-compatible endpoint)
API_BASE_URL=https://openrouter.ai/api/v1
API_KEY=your-openrouter-api-key-here
API_MODEL=qwen/qwen3.5-35b-a3b
API_TIMEOUT=120

# ADB Configuration (for Docker)
# When running in Docker, this connects to the host's ADB server
ADB_SERVER_SOCKET=tcp:host.docker.internal:5037
